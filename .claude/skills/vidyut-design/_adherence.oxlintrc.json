{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/motion/**",
              "components/pairing/**",
              "ui_kits/android/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Material Icons|Material Icons Outlined))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Material Icons, Material Icons Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|icon|muted|fullWidth|onClick|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, icon, muted, fullWidth, onClick, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|outlined|text)$/]",
        "message": "<Button> variant must be one of 'filled' | 'outlined' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|emphasis)$/]",
        "message": "<Card> variant must be one of 'default' | 'emphasis'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Entrance'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|children|style|key|ref|className|style|children)$/]",
        "message": "<Entrance> doesn't accept that prop. Declared props: index, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|color|size|radius|title|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, color, size, radius, title, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ManualPairingForm'] > JSXAttribute > JSXIdentifier[name!=/^(?:host|port|secret|onHostChange|onPortChange|onSecretChange|error|onScanQr|onPair|key|ref|className|style|children)$/]",
        "message": "<ManualPairingForm> doesn't accept that prop. Declared props: host, port, secret, onHostChange, onPortChange, onSecretChange, error, onScanQr, onPair."
      },
      {
        "selector": "JSXOpeningElement[name.name='MIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|outlined|style|key|ref|className|style|children)$/]",
        "message": "<MIcon> doesn't accept that prop. Declared props: name, size, color, outlined, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MorphingBlob'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|children|key|ref|className|style|children)$/]",
        "message": "<MorphingBlob> doesn't accept that prop. Declared props: size, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='NearbyRelaysCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:relays|selected|discovering|onRefresh|onSelect|key|ref|className|style|children)$/]",
        "message": "<NearbyRelaysCard> doesn't accept that prop. Declared props: relays, selected, discovering, onRefresh, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='PressableScale'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<PressableScale> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PulsingDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|key|ref|className|style|children)$/]",
        "message": "<PulsingDot> doesn't accept that prop. Declared props: color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RippleRings'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|children|key|ref|className|style|children)$/]",
        "message": "<RippleRings> doesn't accept that prop. Declared props: size, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Snackbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Snackbar> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|value|onChange|type|placeholder|error|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, icon, value, onChange, type, placeholder, error, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
