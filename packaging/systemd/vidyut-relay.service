[Unit]
Description=Vidyut clipboard relay
Documentation=https://github.com/Snehit70/vidyut
# The relay drives wl-copy/wl-paste, so it only makes sense inside a Wayland session.
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=exec
ExecStart=%h/.local/bin/vidyut-relay --log-level info
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
